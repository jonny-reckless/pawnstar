{
  "configurations": [
    {
      "name": "linux-gcc-x64",
      "includePath": [
        "${workspaceFolder}/**",
        "/usr/include"
      ],
      "defines": [
        "DEBUGX=1",
        "POSIX_C_SOURCE=200809L"
      ],
      "configurationProvider": "ms-vscode.makefile-tools",
      "cStandard": "c17",
      "compilerPath": "/usr/bin/gcc",
      "intelliSenseMode": "linux-gcc-x64"
    }
  ],
  "version": 4
}