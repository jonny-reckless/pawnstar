{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch pawnstar debug",
            "type": "cppdbg",
            "miDebuggerPath": "/usr/bin/gdb",
            "request": "launch",
            "stopAtEntry": true,
            "cwd": "${workspaceFolder}/debug",
            "program": "${workspaceFolder}/debug/pawnstar",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set hex output",
                    "text": "set output-radix 10",
                    "ignoreFailures": false
                }
            ]
        },
        {
            "name": "Launch pawnstar release",
            "type": "cppdbg",
            "miDebuggerPath": "/usr/bin/gdb",
            "request": "launch",
            "stopAtEntry": true,
            "cwd": "${workspaceFolder}/release",
            "program": "${workspaceFolder}/release/pawnstar",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set hex output",
                    "text": "set output-radix 10",
                    "ignoreFailures": false
                }
            ]
        },
        {
            "name": "Launch generate constants",
            "type": "cppdbg",
            "miDebuggerPath": "/usr/bin/gdb",
            "request": "launch",
            "stopAtEntry": true,
            "cwd": "${workspaceFolder}/generate_constants",
            "program": "${workspaceFolder}/generate_constants/gen_constants",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set hex output",
                    "text": "set output-radix 16",
                    "ignoreFailures": false
                }
            ]
        },
        {
            "name": "(gdb) Attach",
            "type": "cppdbg",
            "request": "attach",
            "program": "${workspaceFolder}/debug/pawnstar",
            "processId": "${command:pickProcess}",
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set hex output",
                    "text": "set output-radix 16",
                    "ignoreFailures": false
                }
            ]
        }
    ]
}