{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch pawnstar",
      "type": "cppdbg",
      "miDebuggerPath": "/usr/bin/gdb",
      "request": "launch",
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}/build",
      "program": "${workspaceFolder}/build/pawnstar",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        },
        {
          "description": "Set hex output",
          "text": "set output-radix 10",
          "ignoreFailures": false
        }
      ]
    },
    {
      "name": "Launch generate constants",
      "type": "cppdbg",
      "miDebuggerPath": "/usr/bin/gdb",
      "request": "launch",
      "stopAtEntry": true,
      "cwd": "${workspaceFolder}/generate_constants",
      "program": "${workspaceFolder}/generate_constants/gen_constants",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        },
        {
          "description": "Set hex output",
          "text": "set output-radix 16",
          "ignoreFailures": false
        }
      ]
    },
    {
      "name": "(gdb) Attach",
      "type": "cppdbg",
      "request": "attach",
      "program": "${workspaceFolder}/build/pawnstar",
      "processId": "${command:pickProcess}",
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        },
        {
          "description": "Set hex output",
          "text": "set output-radix 16",
          "ignoreFailures": false
        }
      ]
    },
    {
      "name": "C/C++ Runner: Debug Session",
      "type": "cppdbg",
      "request": "launch",
      "args": [],
      "stopAtEntry": false,
      "externalConsole": false,
      "cwd": "/home/jonny/work/pawnstar",
      "program": "/home/jonny/work/pawnstar/build/Debug/outDebug",
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}