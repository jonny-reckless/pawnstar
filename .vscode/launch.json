{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Apple launch pawnstar debug",
            "type": "lldb",
            "request": "launch",
            "cwd": "${workspaceFolder}/debug",
            "program": "${workspaceFolder}/debug/pawnstar",
        },
        {
            "name": "Apple launch pawnstar release",
            "type": "lldb",
            "request": "launch",
            "cwd": "${workspaceFolder}/release",
            "program": "${workspaceFolder}/release/pawnstar",
        },
        {
            "name": "Launch generate constants",
            "type": "cppdbg",
            "request": "launch",
            "miDebuggerPath": "C:\\msys64\\usr\\bin\\gdb.exe",
            "stopAtEntry": true,
            "cwd": "${workspaceFolder}/generate_constants",
            "program": "${workspaceFolder}/generate_constants/gen_constants",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
    ]
}